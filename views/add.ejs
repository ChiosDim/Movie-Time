<%- include('partials/header.ejs'); -%>

<div class="form-card">
  <h1 class="form-title">Add New Movie</h1>

  <% if (errorMessage) { %>
    <div id="error-message" role="alert">
      <i class="fas fa-exclamation-circle" aria-hidden="true"></i>
      <span><%= errorMessage %></span>
    </div>
  <% } %>

  <form action="/add" method="post" novalidate>
    <div class="form-group">
      <label for="newItem">Movie Title <span aria-hidden="true">*</span></label>
      <div class="search-input-wrapper">
        <input
          type="text"
          id="newItem"
          name="newItem"
          value="<%= formData.title || '' %>"
          placeholder="Search for a movie..."
          required
          autocomplete="off"
          aria-describedby="newItem-hint"
          aria-autocomplete="list"
          aria-controls="search-dropdown"
        />
        <div
          id="search-dropdown"
          class="search-dropdown"
          role="listbox"
          aria-label="Movie suggestions"
        ></div>
      </div>
      <small class="form-hint" id="newItem-hint">Type at least 2 characters to search and auto-fill details</small>
    </div>

    <div class="form-group">
      <label for="director">Director <span aria-hidden="true">*</span></label>
      <input
        type="text"
        id="director"
        name="director"
        value="<%= formData.director || '' %>"
        placeholder="e.g. Christopher Nolan"
        required
        autocomplete="off"
      />
    </div>

    <div class="form-group">
      <label for="rating">Rating (1&ndash;10) <span aria-hidden="true">*</span></label>
      <input
        type="number"
        id="rating"
        name="rating"
        value="<%= formData.rating || 5 %>"
        min="1"
        max="10"
        step="0.1"
        placeholder="e.g. 8.5"
        required
        aria-describedby="rating-hint"
      />
      <small class="form-hint" id="rating-hint">Enter a value between 1 and 10</small>
    </div>

    <div class="form-group">
      <label for="description">Description <span aria-hidden="true">*</span></label>
      <textarea
        id="description"
        name="description"
        placeholder="Briefly describe the movie's plot..."
        required
        rows="4"
      ><%= formData.description || '' %></textarea>
    </div>

    <div class="form-group">
      <label for="userComment">Your Comment <span class="text-muted text-sm">(optional)</span></label>
      <textarea
        id="userComment"
        name="userComment"
        placeholder="Share your personal take on this film..."
        rows="3"
      ><%= formData.userComment || '' %></textarea>
    </div>

    <div class="form-actions">
      <a href="/" class="btn btn-secondary">
        <i class="fas fa-times" aria-hidden="true"></i>
        Cancel
      </a>
      <button type="submit" class="btn btn-primary">
        <i class="fas fa-plus" aria-hidden="true"></i>
        Add Movie
      </button>
    </div>
  </form>
</div>

<script src="/js/add.js" defer></script>

<%- include('partials/footer.ejs'); -%>