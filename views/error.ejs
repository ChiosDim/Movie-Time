<%- include('partials/header.ejs'); -%>

<div class="error-page">
  <div class="error-code" aria-hidden="true"><%= statusCode || 500 %></div>

  <div class="error-icon-wrapper" aria-hidden="true">
    <% if (statusCode === 404) { %>
      <i class="fas fa-search"></i>
    <% } else { %>
      <i class="fas fa-exclamation-triangle"></i>
    <% } %>
  </div>

  <h1>
    <% if (statusCode === 404) { %>
      Page Not Found
    <% } else { %>
      Something Went Wrong
    <% } %>
  </h1>

  <div class="error-card">
    <p>
      <%= error || 'An unexpected error occurred.' %>
    </p>
    <% if (statusCode === 404) { %>
      <p class="text-muted text-sm" style="margin: 0;">
        The page or resource you&rsquo;re looking for doesn&rsquo;t exist or may have been moved.
      </p>
    <% } else { %>
      <p class="text-muted text-sm" style="margin: 0;">
        Please try again. If the problem persists, check back later.
      </p>
    <% } %>
  </div>

  <div class="error-actions">
    <a href="/" class="btn btn-primary btn-lg">
      <i class="fas fa-home" aria-hidden="true"></i>
      Go Home
    </a>
    <a href="/add" class="btn btn-secondary btn-lg">
      <i class="fas fa-plus" aria-hidden="true"></i>
      Add Movie
    </a>
  </div>
</div>

<%- include('partials/footer.ejs'); -%>
