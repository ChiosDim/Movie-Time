<%- include('partials/header.ejs'); -%>

<div class="page-header">
  <h1>My Movie Collection</h1>
  <div class="page-header-meta">
    <% if (movies.length > 0) { %>
      <span class="movie-count-badge">
        <i class="fas fa-film" aria-hidden="true"></i>
        <%= movies.length %> <%= movies.length === 1 ? 'movie' : 'movies' %>
      </span>
      <div class="sort-controls">
        <span class="sort-label">Sort by:</span>
        <div class="custom-select" id="sortDropdown">
          <button class="custom-select-trigger" type="button" aria-haspopup="listbox" aria-expanded="false">
            <span class="custom-select-value">
              <% if (currentSort === 'title') { %>Title
              <% } else if (currentSort === 'director') { %>Director
              <% } else if (currentSort === 'rating') { %>Rating
              <% } else { %>Title<% } %>
            </span>
            <i class="fas fa-chevron-down custom-select-arrow" aria-hidden="true"></i>
          </button>
          <ul class="custom-select-dropdown" role="listbox">
            <li role="option">
              <a href="/?sortBy=title" class="custom-select-option<% if(currentSort==='title'){%> selected<%}%>">
                <i class="fas fa-sort-alpha-down" aria-hidden="true"></i>
                Title
              </a>
            </li>
            <li role="option">
              <a href="/?sortBy=director" class="custom-select-option<% if(currentSort==='director'){%> selected<%}%>">
                <i class="fas fa-user" aria-hidden="true"></i>
                Director
              </a>
            </li>
            <li role="option">
              <a href="/?sortBy=rating" class="custom-select-option<% if(currentSort==='rating'){%> selected<%}%>">
                <i class="fas fa-star" aria-hidden="true"></i>
                Rating
              </a>
            </li>
          </ul>
        </div>
      </div>
    <% } %>
  </div>
</div>

<% if (movies.length === 0) { %>
  <div class="empty-state">
    <div class="empty-state-icon" aria-hidden="true">
      <i class="fas fa-film"></i>
    </div>
    <h2>No movies yet</h1>
    <p>Start building your personal movie collection by adding your first film.</p>
    <a href="/add" class="btn btn-primary btn-lg">
      <i class="fas fa-plus" aria-hidden="true"></i>
      Add Your First Movie
    </a>
  </div>
<% } else { %>
  <div class="movies-grid" id="movie-details" aria-label="Movie collection">
    <% const templateCsrfToken = csrfToken; %>
    <% movies.forEach(function(movie) { %>
      <article class="movie-card fade-in" aria-label="<%= movie.title %>">
        <div class="movie-poster">
          <img
            src="<%= movie.cover_url || 'data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAwIiBoZWlnaHQ9IjMwMCI+PHJlY3Qgd2lkdGg9IjIwMCIgaGVpZ2h0PSIzMDAiIGZpbGw9IiNmZmYiLz48dGV4dCB4PSIwIiB5PSIxNTAiIGZvbnQtZmFtaWx5PSJBcmlhbCIgZm9udC1zaXplPSIxOCIgZmlsbD0iI2MwMCI+PnBsYWNlaG9sZD48L3RleHQ+PC9zdmc+' %>"
            alt="<%= movie.title %> poster"
            loading="lazy"
          />
          <div class="movie-poster-overlay" aria-hidden="true"></div>
          <div class="movie-rating-badge" aria-label="Rating: <%= movie.rating %> out of 10">
            <i class="fas fa-star" aria-hidden="true"></i>
            <span><%= parseFloat(movie.rating).toFixed(1) %></span>
          </div>
        </div>

        <div class="movie-body">
          <h2 class="movie-title-text"><%= movie.title %></h2>
          <p class="movie-director-text">
            <i class="fas fa-video" aria-hidden="true"></i>
            <%= movie.director %>
          </p>
          <% if (movie.description) { %>
            <p class="movie-description-text"><%= movie.description %></p>
          <% } %>
          <% if (movie.userComment) { %>
            <div class="movie-user-comment">
              <i class="fas fa-quote-left" aria-hidden="true"></i>
              <p><%= movie.userComment %></p>
            </div>
          <% } %>
        </div>

        <div class="movie-actions">
          <a
            href="/update/<%= movie.id %>"
            class="btn btn-primary"
            aria-label="Edit <%= movie.title %>"
          >
            <i class="fas fa-pencil-alt" aria-hidden="true"></i>
            Edit
          </a>
          <form
            action="/delete/<%= movie.id %>"
            method="post"
            class="delete-form"
            data-movie-title="<%= movie.title %>"
          >
            <input type="hidden" name="_csrf" value="<%= templateCsrfToken %>">
            <button
              type="submit"
              class="btn btn-delete"
              aria-label="Delete <%= movie.title %>"
            >
              <i class="fas fa-trash" aria-hidden="true"></i>
              Delete
            </button>
          </form>
        </div>
      </article>
    <% }); %>
  </div>
<% } %>

<script src="/js/index.js" defer></script>

<%- include('partials/footer.ejs'); -%>